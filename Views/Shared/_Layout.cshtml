<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ELO Hub Urbano</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        /* Tipografia e Base */
        body { font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background-color: #f8f9fa; }
        .fw-black { font-weight: 900 !important; }
        
        /* Menu Glassmorphism Premium */
        .navbar-glass {
            background: rgba(255, 255, 255, 0.95) !important;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05) !important;
        }
        
        .nav-link { 
            font-weight: 600;
            color: #495057 !important;
            transition: color 0.3s ease;
            padding: 0.5rem 1rem !important;
            font-size: 0.95rem;
        }
        .nav-link:hover { color: #198754 !important; }
        
        /* Destaque para o Link "Acesso Prefeituras" */
        .nav-link-prefeitura {
            color: #198754 !important;
            background-color: rgba(25, 135, 84, 0.05);
            border-radius: 8px;
            padding-left: 1rem !important;
            padding-right: 1rem !important;
        }
        .nav-link-prefeitura:hover {
            background-color: rgba(25, 135, 84, 0.1);
        }

        /* Dropdowns Suaves */
        .dropdown-menu { border: 1px solid rgba(0,0,0,0.05); box-shadow: 0 10px 30px rgba(0,0,0,0.08); border-radius: 12px; padding: 0.5rem; }
        .dropdown-item { border-radius: 8px; font-weight: 600; font-size: 0.9rem; transition: all 0.2s; }
        .dropdown-item:hover { background-color: #f8f9fa; transform: translateX(3px); }
        @@media (min-width: 992px) { .dropdown:hover .dropdown-menu { display: block; margin-top: 0; } }

        /* Botões de Alta Conversão (CTA) */
        .btn-cta {
            background: linear-gradient(135deg, #e63946 0%, #d90429 100%);
            color: white !important;
            border: none;
            box-shadow: 0 4px 15px rgba(226, 57, 70, 0.3);
            transition: all 0.3s ease;
        }
        .btn-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(226, 57, 70, 0.4); }
        
        .btn-login {
            border: 2px solid #e9ecef; color: #495057; background: transparent; transition: all 0.3s ease;
        }
        .btn-login:hover { border-color: #198754; color: #198754; background: transparent; }

        /* Rodapé Premium */
        .footer-premium { background-color: #ffffff; border-top: 1px solid rgba(0,0,0,0.05); padding-top: 4rem; padding-bottom: 2rem; }
        .footer-link { color: #6c757d; text-decoration: none; transition: color 0.2s ease; font-size: 0.9rem; }
        .footer-link:hover { color: #198754; }
        .social-icon { width: 35px; height: 35px; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; background: #f8f9fa; color: #495057; transition: all 0.3s ease; text-decoration: none; }
        .social-icon:hover { background: #198754; color: white; transform: translateY(-3px); }

        /* Animação do Botão Flutuante Mobile */
        @@keyframes pulse-ring {
            0% { transform: scale(0.8); box-shadow: 0 0 0 0 rgba(226, 57, 70, 0.5); }
            70% { transform: scale(1); box-shadow: 0 0 0 15px rgba(226, 57, 70, 0); }
            100% { transform: scale(0.8); box-shadow: 0 0 0 0 rgba(226, 57, 70, 0); }
        }
        .pulse-btn { animation: pulse-ring 2s infinite; }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-lg navbar-light navbar-glass fixed-top py-3">
            <div class="container">
                
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index" style="padding: 0;">
                    <img src="~/images/logo-elo.svg" alt="Logo ELO Hub Urbano" style="height: 85px; width: auto; transform: scale(1.6); transform-origin: left center; filter: drop-shadow(0px 2px 4px rgba(0,0,0,0.08));" />
                </a>
                
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarELO">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarELO">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 align-items-center">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Início</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Sobre">Sobre Nós</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Educacao" asp-action="Index">Educação</a></li>
                        
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                Nossas Soluções
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item mb-1 py-2" asp-controller="Parceiros" asp-action="Index"><i class="fas fa-gift me-2 text-warning opacity-75"></i>Clube de Recompensas</a></li>
                                <li><a class="dropdown-item mb-1 py-2" asp-controller="Empresas" asp-action="Index"><i class="fas fa-building me-2 text-secondary opacity-75"></i>Para Empresas</a></li>
                                <li><a class="dropdown-item mb-1 py-2" asp-controller="Home" asp-action="Prefeituras"><i class="fas fa-landmark me-2 text-success opacity-75"></i>Para Prefeituras</a></li>
                                <li><a class="dropdown-item mb-1 py-2" asp-controller="Parceiros" asp-action="PainelLojista"><i class="fas fa-store-alt me-2 text-primary opacity-75"></i>Painel do Lojista</a></li>
                            </ul>
                        </li>
                        
                        <li class="nav-item dropdown ms-lg-2 mt-2 mt-lg-0">
                            <a class="nav-link dropdown-toggle nav-link-prefeitura fw-bold" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-lock me-1"></i> Acesso Restrito
                            </a>
                            <ul class="dropdown-menu border-0 shadow-lg">
                                <li><a class="dropdown-item text-success mb-1 py-2 fw-bold" asp-controller="Admin" asp-action="Index"><i class="fas fa-chart-line me-2 opacity-75"></i>Painel do Município</a></li>
                                <li><a class="dropdown-item mb-1 py-2 fw-bold text-dark" asp-controller="Ocorrencias" asp-action="Dashboard"><i class="fas fa-map-marked-alt me-2 opacity-75 text-danger"></i>Central de Monitoramento</a></li>
                            </ul>
                        </li>
                    </ul>
                    
                    <div class="d-flex align-items-center gap-3 mt-3 mt-lg-0">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown d-none d-lg-block">
                                <a class="btn btn-light fw-bold rounded-pill px-4 border shadow-sm dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                                    <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px; font-size: 0.7rem;">
                                        <i class="fas fa-user"></i>
                                    </div>
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item text-danger py-2" asp-controller="Login" asp-action="Sair"><i class="fas fa-sign-out-alt me-2"></i>Sair da Conta</a></li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-login fw-bold rounded-pill px-4 d-none d-lg-inline-block" asp-controller="Login" asp-action="Index">
                                Entrar
                            </a>
                        }
                        
                        <button type="button" class="btn btn-cta fw-bold rounded-pill px-4 d-none d-lg-inline-block" data-bs-toggle="modal" data-bs-target="#modalBotaoMae">
                            <i class="fas fa-location-arrow me-1"></i> Criar Denúncia
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1" style="margin-top: 85px;">
        @RenderBody()
    </main>

    <footer class="footer-premium mt-auto">
        <div class="container">
            <div class="row gy-4 mb-4">
                <div class="col-lg-4 col-md-6 pe-lg-5">
                    <h5 class="fw-black mb-3 d-flex align-items-center text-dark">
                        <img src="~/images/logo-elo.svg" alt="Símbolo ELO" style="height: 30px; margin-right: 10px;" /> ELO Hub
                    </h5>
                    <p class="text-muted small lh-lg mb-4">
                        A plataforma definitiva de Zeladoria Inteligente e Economia Circular. Conectando o cidadão, o poder público e o comércio local para construir cidades mais inteligentes e sustentáveis.
                    </p>
                    <div class="d-flex gap-2">
                        <a href="#" class="social-icon"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-github"></i></a>
                    </div>
                </div>

                <div class="col-lg-2 col-md-6 col-6">
                    <h6 class="fw-bold text-dark text-uppercase mb-3" style="font-size: 0.8rem; letter-spacing: 1px;">Soluções</h6>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><a href="#" class="footer-link">Para Cidadãos</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Prefeituras" class="footer-link text-success fw-bold">Para Prefeituras</a></li>
                        <li class="mb-2"><a asp-controller="Empresas" asp-action="Index" class="footer-link">Comércio Parceiro</a></li>
                        <li class="mb-2"><a asp-controller="Parceiros" asp-action="Index" class="footer-link">Clube de Benefícios</a></li>
                    </ul>
                </div>

                <div class="col-lg-2 col-md-6 col-6">
                    <h6 class="fw-bold text-dark text-uppercase mb-3" style="font-size: 0.8rem; letter-spacing: 1px;">A Startup</h6>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><a asp-controller="Home" asp-action="Sobre" class="footer-link">Sobre Nós</a></li>
                        <li class="mb-2"><a asp-controller="Educacao" asp-action="Index" class="footer-link">Blog & Educação</a></li>
                        <li class="mb-2"><a href="#" class="footer-link">Casos de Sucesso</a></li>
                        <li class="mb-2"><a href="#" class="footer-link">Contato</a></li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-6">
                    <h6 class="fw-bold text-dark text-uppercase mb-3" style="font-size: 0.8rem; letter-spacing: 1px;">Legal & Suporte</h6>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><a asp-controller="Home" asp-action="Privacy" class="footer-link">Política de Privacidade</a></li>
                        <li class="mb-2"><a href="#" class="footer-link">Termos de Serviço</a></li>
                        <li class="mb-2"><a href="#" class="footer-link">Central de Ajuda</a></li>
                    </ul>
                    <div class="mt-4 p-3 bg-light rounded-4 border">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-headset fa-2x text-success opacity-75 me-3"></i>
                            <div>
                                <h6 class="fw-bold mb-0 text-dark small">Suporte Exclusivo</h6>
                                <span class="text-muted small">suporte@elohub.com.br</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <hr class="text-muted opacity-10 my-4" />
            
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="text-muted small mb-0 fw-bold">&copy; 2026 ELO Hub Urbano. Todos os direitos reservados.</p>
                </div>
                <div class="col-md-6 text-center text-md-end mt-2 mt-md-0">
                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill">
                        <i class="fas fa-shield-alt me-1"></i> Ambiente Seguro
                    </span>
                </div>
            </div>
        </div>
    </footer>

    <div class="position-fixed p-3 d-lg-none pulse-btn" style="bottom: 20px; right: 10px; z-index: 1050;">
        <button type="button" class="btn btn-cta rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;" data-bs-toggle="modal" data-bs-target="#modalBotaoMae">
            <i class="fas fa-location-arrow fa-lg"></i>
        </button>
    </div>

    <div class="modal fade" id="modalBotaoMae" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow-lg">
                <div class="modal-header border-0 rounded-top-4 p-4" style="background: linear-gradient(135deg, #e63946 0%, #d90429 100%);">
                    <h5 class="modal-title fw-black text-white"><i class="fas fa-location-arrow me-2"></i> Registrar Ocorrência</h5>
                    <button type="button" class="btn-close btn-close-white opacity-75" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-5 text-center">
                    <h6 class="text-dark mb-4 fw-bold">Como podemos ajudar sua cidade hoje?</h6>
                    
                    <div class="d-grid gap-3">
                        <a asp-controller="Ocorrencias" asp-action="Registrar" asp-route-categoria="Residuos" class="btn btn-light border btn-lg rounded-4 fw-bold py-3 text-start d-flex align-items-center transition-hover" style="color: #495057;">
                            <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3 d-flex align-items-center justify-content-center">
                                <i class="fas fa-recycle text-success fa-lg"></i>
                            </div>
                            <div>
                                <div class="mb-0">Zeladoria Urbana</div>
                                <small class="text-muted fw-normal" style="font-size: 0.75rem;">Buracos, entulhos, iluminação</small>
                            </div>
                        </a>
                        
                        <a asp-controller="Ocorrencias" asp-action="Registrar" asp-route-categoria="ProtecaoAnimal" class="btn btn-light border btn-lg rounded-4 fw-bold py-3 text-start d-flex align-items-center transition-hover" style="color: #495057;">
                            <div class="bg-info bg-opacity-10 p-3 rounded-circle me-3 d-flex align-items-center justify-content-center">
                                <i class="fas fa-paw text-info fa-lg"></i>
                            </div>
                            <div>
                                <div class="mb-0">Proteção Animal</div>
                                <small class="text-muted fw-normal" style="font-size: 0.75rem;">Maus-tratos, resgates, abandono</small>
                            </div>
                        </a>
                    </div>
                </div> 
                <div class="modal-footer bg-light border-0 rounded-bottom-4 justify-content-center p-3">
                    <span class="small text-muted fw-bold"><i class="fas fa-coins text-warning me-1"></i> Relatos confirmados geram ELO Cashback!</span>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>