@model EcoCicloPortal.Models.Prefeitura

@{
    ViewData["Title"] = "Cadastrar Novo Município";
}

<div class="container my-5 py-4" data-aos="fade-up">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            
            <div class="d-flex align-items-center mb-4">
                <div class="bg-success rounded-circle p-3 text-white me-3 shadow-sm">
                    <i class="fas fa-city fa-2x"></i>
                </div>
                <div>
                    <h2 class="fw-bold text-dark mb-0">Novo Contrato SaaS</h2>
                    <p class="text-muted small mb-0">Ative uma nova prefeitura no ecossistema ELO Hub.</p>
                </div>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white p-4 border-0">
                    <h5 class="fw-bold mb-0"><i class="fas fa-file-signature me-2 text-success"></i> Dados do Cliente Institucional</h5>
                </div>
                <div class="card-body p-5">
                    <form asp-action="NovaPrefeitura" method="post">
                        
                        <div class="row g-4">
                            <div class="col-md-12">
                                <label asp-for="Nome" class="form-label fw-bold text-muted small text-uppercase">Razão Social / Nome</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-landmark text-muted"></i></span>
                                    <input asp-for="Nome" class="form-control bg-light border-start-0" placeholder="Ex: Prefeitura Municipal de Barra Bonita" required>
                                </div>
                                <span asp-validation-for="Nome" class="text-danger small"></span>
                            </div>

                            <div class="col-md-5">
                                <label asp-for="CNPJ" class="form-label fw-bold text-muted small text-uppercase">CNPJ</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-id-card text-muted"></i></span>
                                    <input asp-for="CNPJ" class="form-control bg-light border-start-0" placeholder="00.000.000/0001-00">
                                </div>
                            </div>

                            <div class="col-md-5">
                                <label asp-for="Cidade" class="form-label fw-bold text-muted small text-uppercase">Cidade</label>
                                <input asp-for="Cidade" class="form-control bg-light" placeholder="Ex: Barra Bonita" required>
                            </div>

                            <div class="col-md-2">
                                <label asp-for="Estado" class="form-label fw-bold text-muted small text-uppercase">UF</label>
                                <input asp-for="Estado" class="form-control bg-light text-center" placeholder="SP" maxlength="2" required>
                            </div>

                            <div class="col-12"><hr class="text-muted opacity-25 my-2"></div>

                            <div class="col-md-6">
                                <label asp-for="ValorMensalidade" class="form-label fw-bold text-success small text-uppercase">Mensalidade ELO (MRR)</label>
                                <div class="input-group mb-2">
                                    <span class="input-group-text bg-success text-white border-0 fw-bold">R$</span>
                                    <input asp-for="ValorMensalidade" type="number" step="0.01" class="form-control border-success border-2 fw-bold text-success" placeholder="2500,00" required>
                                </div>
                                <div class="form-text">Defina o valor do contrato. O acesso é liberado automaticamente após salvar.</div>
                            </div>

                            <div class="col-md-12 mt-5">
                                <button type="submit" class="btn btn-dark btn-lg w-100 rounded-pill fw-bold shadow-sm transition-hover">
                                    <i class="fas fa-check-circle me-2"></i> Ativar Cliente na Plataforma
                                </button>
                                <div class="text-center mt-3">
                                    <a asp-action="Index" class="text-decoration-none text-muted small fw-bold hover-danger">
                                        <i class="fas fa-times me-1"></i> Cancelar e Voltar
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .transition-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
    }
    .hover-danger:hover {
        color: #dc3545 !important;
    }
    .form-control, .input-group-text {
        padding: 0.75rem 1rem;
    }
    .form-control:focus {
        border-color: #198754;
        box-shadow: none;
    }
    .input-group:focus-within .input-group-text {
        border-color: #198754;
        color: #198754 !important;
    }
</style>