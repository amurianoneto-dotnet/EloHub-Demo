@model EcoCicloPortal.Models.DashboardViewModel

@{
    // 1. PRIMEIRO: Declaramos as variáveis e lemos quem está logado
    ViewData["Title"] = "Central de Monitoramento";
    bool isParceiro = ViewBag.Perfil == "Parceiro";
    string nomeOrgao = ViewBag.OrgaoVinculado ?? "Administração Central";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
    /* Estilos Premium para o Dashboard */
    .dashboard-header {
        background: linear-gradient(135deg, #198754 0%, #0f5132 100%);
        border-radius: 1rem;
        padding: 2rem;
        color: white;
        margin-bottom: 2rem;
        box-shadow: 0 10px 30px rgba(25, 135, 84, 0.15);
    }
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transform: translateY(-1px);
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    }
    .transition-hover { transition: all 0.2s ease; }
    .transition-hover:hover { transform: translateY(-2px); }
</style>

<div class="container-fluid mt-4 px-lg-4 pb-5">
    
    <div class="dashboard-header d-flex flex-column flex-md-row justify-content-between align-items-md-center">
        <div class="mb-3 mb-md-0">
            <h2 class="fw-black mb-1"><i class="fas fa-satellite-dish me-2 opacity-75"></i> Central de Monitoramento</h2>
            <p class="mb-0 opacity-75 fw-bold" style="letter-spacing: 0.5px;">
                <i class="fas fa-map-marker-alt me-1"></i> @Model.NomeCidade &nbsp;|&nbsp; 
                <i class="fas fa-user-shield ms-2 me-1"></i> Logado como: <span class="badge bg-white text-success ms-1">@nomeOrgao</span>
            </p>
        </div>
        <div class="d-flex gap-2">
            @if (!isParceiro)
            {
                <a href="/Login/CadastrarParceiro" class="btn btn-light text-success fw-bold rounded-pill shadow-sm transition-hover">
                    <i class="fas fa-plus-circle me-1"></i> Novo Órgão
                </a>
            }
            <button onclick="gerarRelatorioPDF()" class="btn btn-outline-light fw-bold rounded-pill transition-hover">
                <i class="fas fa-file-pdf me-1"></i> Exportar PMVA
            </button>
        </div>
    </div>

    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-4 border-0 mb-4 fw-bold" role="alert">
            <i class="fas fa-check-circle fa-lg me-2"></i> @TempData["MensagemSucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4 pb-2 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-dark mb-0"><i class="fas fa-map-marked-alt text-success me-2"></i> Radar de Ocorrências</h5>
                    <span class="badge bg-light text-muted border"><i class="fas fa-circle text-danger me-1" style="font-size: 0.5rem;"></i> Ao Vivo</span>
                </div>
                <div class="card-body p-4 pt-2">
                    <div id="mapDashboard" style="height: 450px; z-index: 1;" class="rounded-4 border shadow-inner"></div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div id="area-relatorio" class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4 pb-3 px-4">
                    <h5 class="fw-bold text-dark mb-0"><i class="fas fa-inbox text-primary me-2"></i> Fluxo de Demandas</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="font-size: 0.95rem;">
                            <thead class="table-light text-muted small text-uppercase" style="letter-spacing: 0.5px;">
                                <tr>
                                    <th class="ps-4">Data/Hora</th>
                                    <th>Categoria</th>
                                    <th>Ocorrência</th>
                                    <th>Endereço Local</th>
                                    <th class="text-center">Ação / Status</th>
                                </tr>
                            </thead>
                            <tbody class="border-top-0">
                                @foreach (var oc in Model.Ocorrencias)
                                {
                                    <tr>
                                        <td class="ps-4 text-muted fw-bold small">
                                            @oc.DataRegistro.ToString("dd/MM/yyyy") <br />
                                            <span class="text-primary"><i class="far fa-clock"></i> @oc.DataRegistro.ToString("HH:mm")</span>
                                        </td>
                                        <td>
                                            @if (oc.Categoria == EcoCicloPortal.Models.CategoriaOcorrencia.ProtecaoAnimal)
                                            {
                                                <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-2 py-1 rounded-pill">
                                                    <i class="fas fa-paw me-1"></i> Voz Animal
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1 rounded-pill">
                                                    <i class="fas fa-recycle me-1"></i> Resíduos
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <strong class="text-dark">@oc.Titulo</strong>
                                        </td>
                                        <td style="max-width: 250px;">
                                            <small class="text-muted text-truncate d-block" title="@oc.Localizacao">
                                                <i class="fas fa-map-pin text-danger opacity-75 me-1"></i> @oc.Localizacao
                                            </small>
                                        </td>
                                        
                                        <td class="text-center pe-4">
                                            @if (oc.Status == "Pendente")
                                            {
                                                <form asp-controller="Ocorrencias" asp-action="AssumirCaso" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@oc.Id" />
                                                    <button type="submit" class="btn btn-sm btn-primary rounded-pill fw-bold shadow-sm transition-hover px-3">
                                                        <i class="fas fa-hand-paper me-1"></i> Assumir
                                                    </button>
                                                </form>
                                            }
                                            else if (oc.Status == "Em Andamento")
                                            {
                                                <div class="d-flex align-items-center justify-content-center gap-2">
                                                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill shadow-sm" title="Assumido por: @oc.OrgaoAtendente">
                                                        <i class="fas fa-tools me-1"></i> @(string.IsNullOrEmpty(oc.OrgaoAtendente) ? "Em Andamento" : oc.OrgaoAtendente)
                                                    </span>
                                                    
                                                    <form asp-controller="Ocorrencias" asp-action="ResolverOcorrencia" method="post" class="m-0">
                                                        <input type="hidden" name="id" value="@oc.Id" />
                                                        <button type="submit" class="btn btn-sm btn-success rounded-circle shadow-sm transition-hover" title="Marcar como Resolvido" style="width: 32px; height: 32px; padding: 0;">
                                                            <i class="fas fa-check"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                            else
                                            {
                                                 <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill">
                                                     <i class="fas fa-check-double me-1"></i> Resolvido
                                                 </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    // Centro de Barra Bonita
    var mapDash = L.map('mapDashboard').setView([-22.5111, -48.5581], 14); 

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(mapDash);

    // O C# injeta as coordenadas direto no JavaScript
    @foreach (var oc in Model.Ocorrencias.Where(o => o.Latitude != null && o.Longitude != null))
    {
        string corPino = oc.Categoria == EcoCicloPortal.Models.CategoriaOcorrencia.ProtecaoAnimal ? "#0dcaf0" : "#198754";
        string iconePino = oc.Categoria == EcoCicloPortal.Models.CategoriaOcorrencia.ProtecaoAnimal ? "🐾" : "🌿";

        <text>
            var marker = L.circleMarker([@oc.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture), @oc.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)], {
            color: '@corPino',
            fillColor: '@corPino',
            fillOpacity: 0.8,
            weight: 2,
            radius: 8
            }).addTo(mapDash);

            marker.bindPopup("<div style='text-align:center;'><b>@iconePino @oc.Titulo</b><br><span class='badge bg-light text-dark border my-1'>@oc.Status</span><br><small class='text-muted'>@oc.Localizacao</small></div>");
        </text>
    }
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    function gerarRelatorioPDF() {
        var elemento = document.getElementById('area-relatorio');
        
        var opt = {
            margin:       0.5,
            filename:     'Relatorio_PMVA_BarraBonita.pdf',
            image:        { type: 'jpeg', quality: 0.98 },
            html2canvas:  { scale: 2 },
            jsPDF:        { unit: 'in', format: 'a4', orientation: 'landscape' }
        };

        html2pdf().set(opt).from(elemento).save();
    }
</script>