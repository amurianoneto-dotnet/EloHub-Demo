@model IEnumerable<EcoCicloPortal.Models.Ocorrencia>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { font-family: sans-serif; }
        .header { border-bottom: 2px solid #198754; margin-bottom: 20px; }
    </style>
</head>
<body class="p-4">
    <div class="header text-center pb-3">
        <h1 class="text-success">ECOCICLO - Relatório de Monitoramento</h1>
        <p>Documento gerado em: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
    </div>

    <table class="table table-striped border">
        <thead class="table-dark">
            <tr>
                <th>Data</th>
                <th>Cidade/UF</th>
                <th>Título</th>
                <th>Tipo</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.DataRegistro.ToShortDateString()</td>
                    <td>@item.Cidade / @item.Estado</td>
                    <td>@item.Titulo</td>
                    <td>@item.TipoResiduo</td>
                    <td>@item.Status</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>