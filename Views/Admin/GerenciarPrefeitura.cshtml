@model EcoCicloPortal.Models.Prefeitura

<div class="container my-5" data-aos="fade-up">
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted small fw-bold">
            <i class="fas fa-arrow-left me-1"></i> Voltar ao Dashboard Global
        </a>
        <h2 class="fw-black text-dark mt-2">Configurar: @Model.Nome</h2>
        <p class="text-muted">Gerencie os departamentos e o acesso desta prefeitura.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-dark text-white p-3 border-0">
                    <h6 class="fw-bold mb-0"><i class="fas fa-plus-circle me-2 text-success"></i>Novo Órgão/Secretaria</h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="AdicionarOrgao" method="post">
                        <input type="hidden" name="prefeituraId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Nome do Departamento</label>
                            <input type="text" name="nomeOrgao" class="form-control bg-light" placeholder="Ex: Controle de Zoonoses" required>
                        </div>
                        <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold shadow-sm">
                            Criar Órgão
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-bottom p-3">
                    <h6 class="fw-bold mb-0 text-dark"><i class="fas fa-building text-primary me-2"></i>Departamentos Ativos</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light small text-muted text-uppercase">
                                <tr>
                                    <th class="px-4">ID</th>
                                    <th>Nome do Órgão</th>
                                    <th class="text-end px-4">Ação</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Orgaos == null || !Model.Orgaos.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-4 text-muted small">Nenhum órgão cadastrado para esta cidade.</td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var orgao in Model.Orgaos)
                                    {
                                        <tr>
                                            <td class="px-4 text-muted small">#@orgao.Id</td>
                                            <td class="fw-bold text-dark">@orgao.Nome</td>
                                            <td class="text-end px-4">
                                                <button class="btn btn-sm btn-outline-danger border-0"><i class="fas fa-trash"></i></button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>