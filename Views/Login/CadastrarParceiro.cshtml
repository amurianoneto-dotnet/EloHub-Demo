@model EcoCicloPortal.Models.Usuario

@{
    ViewData["Title"] = "Cadastrar Novo Órgão";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4 border-top border-primary border-5">
                <div class="card-body p-5">
                    <h3 class="fw-bold text-primary text-center mb-4"><i class="fas fa-landmark me-2"></i>Cadastrar Órgão Parceiro</h3>
                    <p class="text-muted text-center">Crie um acesso para ONGs, Zoonoses ou Polícia Ambiental.</p>

                    <form asp-controller="Login" asp-action="CadastrarParceiro" method="post">
                        <div class="form-group mb-3">
                            <label asp-for="OrgaoVinculado" class="form-label fw-bold">Nome do Órgão / ONG</label>
                            <input asp-for="OrgaoVinculado" class="form-control" placeholder="Ex: ONG Patinhas Livres" required />
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Nome" class="form-label fw-bold">Nome do Responsável</label>
                            <input asp-for="Nome" class="form-control" placeholder="Nome de quem vai operar o sistema" required />
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Email" class="form-label fw-bold">E-mail de Acesso</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="contato@orgao.com" required />
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Senha" class="form-label fw-bold">Senha de Acesso</label>
                            <input asp-for="Senha" type="text" class="form-control" placeholder="Crie uma senha inicial" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold shadow-sm">
                            Registrar Órgão no Sistema
                        </button>
                        <a href="/Ocorrencias/Dashboard" class="btn btn-outline-secondary w-100 rounded-pill mt-2">Voltar ao Painel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>