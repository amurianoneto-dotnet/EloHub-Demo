@{
    ViewData["Title"] = "Seu Voucher ELO";
    
    // Montando a mensagem automática para o WhatsApp
    string mensagemZap = $"Olá! Acabei de resgatar um benefício pelo ELO Hub.%0A%0A*Parceiro:* {ViewBag.Parceiro}%0A*Voucher:* {ViewBag.Codigo}%0A*Valor/Oferta:* R$ {ViewBag.Valor?.ToString("F2")}%0A%0AEstou enviando para validação no caixa!";
    string linkWhatsApp = $"https://api.whatsapp.com/send?text={mensagemZap}";
}

<div class="container my-5 py-4">
    <div class="row justify-content-center" data-aos="zoom-in">
        <div class="col-md-6 col-lg-5">
            
            <div class="ticket-container shadow-lg">
                
                <div class="ticket-header bg-success text-center p-4 text-white position-relative overflow-hidden">
                    <i class="fas fa-check-circle fa-3x mb-2 text-white"></i>
                    <h3 class="fw-bold mb-0">Resgate Concluído!</h3>
                    <p class="small opacity-75 mb-0">Apresente este protocolo no estabelecimento.</p>
                    <div class="ticket-hole left"></div>
                    <div class="ticket-hole right"></div>
                </div>

                <div class="ticket-body bg-white p-4 pb-2 border-start border-end border-light text-center">
                    <p class="text-uppercase text-muted fw-bold small mb-1 tracking-wide">Parceiro ELO Oficial</p>
                    <h4 class="fw-black text-dark mb-4">@ViewBag.Parceiro</h4>
                    
                    <div class="bg-light rounded-3 p-3 mb-4 border border-dashed border-secondary">
                        <p class="text-muted small mb-1">Valor do Benefício</p>
                        <h2 class="fw-bold text-success mb-0">R$ @ViewBag.Valor?.ToString("F2")</h2>
                    </div>

                    <div class="mb-4">
                        <i class="fas fa-qrcode text-dark opacity-75" style="font-size: 8rem;"></i>
                        <p class="text-muted small mt-2 mb-0">Escaneie no terminal da loja</p>
                    </div>
                </div>

                <div class="ticket-footer bg-white p-4 border-start border-end border-bottom border-light position-relative">
                    <div class="ticket-divider"></div>
                    
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div class="text-start">
                            <span class="d-block text-muted small text-uppercase fw-bold">Cidadão Titular</span>
                            <span class="fw-bold text-dark">@ViewBag.NomeCidadao</span>
                        </div>
                        <div class="text-end">
                            <span class="d-block text-muted small text-uppercase fw-bold">Validade</span>
                            <span class="text-danger fw-bold"><i class="far fa-clock me-1"></i>@ViewBag.DataValidade</span>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top text-center">
                        <span class="d-block text-muted small text-uppercase fw-bold mb-1">Código do Protocolo</span>
                        <span class="fw-black fs-4 text-dark letter-spacing-2">@ViewBag.Codigo</span>
                    </div>
                </div>
            </div>

            <div class="mt-5 text-center">
                <p class="text-muted small mb-3">Prefere validar direto com a loja agora?</p>
                <a href="@linkWhatsApp" target="_blank" class="btn btn-success btn-lg rounded-pill shadow-sm fw-bold w-100 mb-3 transition-hover d-flex align-items-center justify-content-center">
                    <i class="fab fa-whatsapp fs-4 me-2"></i> Enviar Voucher via WhatsApp
                </a>
                
                <a asp-action="Index" class="btn btn-outline-dark rounded-pill fw-bold px-5 transition-hover">
                    Voltar ao Clube
                </a>
            </div>

        </div>
    </div>
</div>

<style>
    /* Estilização do Formato de Ingresso/Ticket */
    .ticket-container {
        border-radius: 1rem;
        overflow: visible;
        position: relative;
    }
    
    .ticket-header {
        border-top-left-radius: 1rem;
        border-top-right-radius: 1rem;
    }
    
    .ticket-footer {
        border-bottom-left-radius: 1rem;
        border-bottom-right-radius: 1rem;
    }

    /* O "picotado" que separa as partes do ingresso */
    .ticket-divider {
        position: absolute;
        top: 0;
        left: 10px;
        right: 10px;
        height: 0;
        border-top: 2px dashed #dee2e6;
    }

    /* Os buraquinhos nas laterais simulando o corte do papel */
    .ticket-hole {
        position: absolute;
        bottom: -15px;
        width: 30px;
        height: 30px;
        background-color: #f8f9fa; /* Cor do fundo do site (bg-light) */
        border-radius: 50%;
        z-index: 10;
    }
    .ticket-hole.left {
        left: -15px;
        box-shadow: inset -3px 0 5px rgba(0,0,0,0.1);
    }
    .ticket-hole.right {
        right: -15px;
        box-shadow: inset 3px 0 5px rgba(0,0,0,0.1);
    }

    .border-dashed {
        border-style: dashed !important;
    }
    
    .fw-black {
        font-weight: 900 !important;
    }
    
    .letter-spacing-2 {
        letter-spacing: 2px;
    }
    
    .tracking-wide {
        letter-spacing: 1.5px;
    }

    .transition-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .transition-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1) !important;
    }
</style>