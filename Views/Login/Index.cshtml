@{
    ViewData["Title"] = "Entrar no Portal";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4 border-top border-success border-5 mt-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-success"><i class="fas fa-sign-in-alt me-2"></i>Acessar Conta</h2>
                        <p class="text-muted">Faça login para relatar problemas e ver seu saldo de Cashback.</p>
                    </div>

                    @if (TempData["MensagemSucesso"] != null)
                    {
                        <div class="alert alert-success rounded-pill text-center shadow-sm">
                            <i class="fas fa-check-circle me-1"></i> @TempData["MensagemSucesso"]
                        </div>
                    }

                    @if (ViewBag.Erro != null)
                    {
                        <div class="alert alert-danger rounded-pill text-center shadow-sm">
                            <i class="fas fa-exclamation-circle me-1"></i> @ViewBag.Erro
                        </div>
                    }

                    <form asp-controller="Login" asp-action="Index" method="post">
                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">E-mail</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light"><i class="fas fa-envelope text-success"></i></span>
                                <input type="email" name="email" class="form-control" placeholder="seu@email.com" required />
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label class="form-label fw-bold">Senha</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light"><i class="fas fa-lock text-success"></i></span>
                                <input type="password" name="senha" class="form-control" placeholder="••••••••" required />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill fw-bold shadow-sm mb-3">
                            Entrar
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted">Ainda não tem uma conta?</p>
                        <a href="/Login/Cadastro" class="btn btn-outline-success rounded-pill px-4">Cadastre-se como Cidadão</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>